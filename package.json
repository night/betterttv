    "postcss-preset-env": "^11.3.2",
    "postcss-url": "10.1.4",
    "prettier": "3.9.5",
    "vite": "8.1.4"
  },
  "overrides": {
    "postcss-url": {
      "minimatch": "^3.1.5"
    },
    "brace-expansion@>=5.0.0 <5.0.6": "^5.0.6",
    "uuid@<11.1.1": "^11.1.1"
  }
